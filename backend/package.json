{
  "name": "stocksense-backend",
  "version": "0.1.0",
  "description": "Backend for StockSense - auth APIs and landing page",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --runInBand",
    "test:ci": "jest --runInBand --ci"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.18.2",
    "google-auth-library": "^9.14.1",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^7.5.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-html-reporters": "^3.1.7",
    "jest-junit": "^16.0.0",
    "mongodb-memory-server": "^9.5.0",
    "nodemon": "^2.0.22",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "globalSetup": "<rootDir>/test/globalSetup.js",
    "globalTeardown": "<rootDir>/test/globalTeardown.js",
    "setupFilesAfterEnv": ["<rootDir>/test/setup.js"],
    "testMatch": ["<rootDir>/test/**/*.test.js"],
    "reporters": [
      "default",
      ["jest-junit", { "outputDirectory": "test-report", "outputName": "backend-junit.xml" }],
      ["jest-html-reporters", { "publicPath": "test-report", "filename": "backend-report.html", "pageTitle": "StockSense Backend Test Report" }]
    ]
  }
}
